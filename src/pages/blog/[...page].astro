---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  );
  return paginate(posts, { pageSize: 2 });
}

const { page } = Astro.props;
---

<Layout title="Blog">
  <Fragment slot="head">
    <meta name="description" content="Articles about Astro, web performance, and modern frontend development." />
    <meta property="og:title" content="Blog" />
    <meta property="og:type" content="website" />
  </Fragment>
  <div class="max-w-2xl mx-auto px-4 py-12">
    <a href="/" class="text-indigo-400 text-sm hover:underline mb-6 inline-block">← Home</a>
    <h1 class="text-4xl font-extrabold bg-gradient-to-br from-indigo-400 to-purple-400 bg-clip-text text-transparent mb-8">
      Blog
    </h1>

    <div class="flex flex-col gap-4 mb-10">
      {page.data.map((post: any) => (
        <a
          href={`/blog/${post.id}`}
          class="block bg-slate-800 border border-slate-700 rounded-xl p-6 hover:border-indigo-400 transition-colors no-underline text-inherit"
        >
          <h2 class="text-lg font-semibold mb-2">{post.data.title}</h2>
          <p class="text-slate-400 text-sm mb-2">{post.data.description}</p>
          <span class="text-slate-500 text-xs">
            {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
          </span>
        </a>
      ))}
    </div>

    <div class="flex items-center justify-between text-sm">
      {page.url.prev
        ? <a href={page.url.prev} class="text-indigo-400 hover:underline">← Newer</a>
        : <span />
      }
      <span class="text-slate-500">Page {page.currentPage} of {page.lastPage}</span>
      {page.url.next
        ? <a href={page.url.next} class="text-indigo-400 hover:underline">Older →</a>
        : <span />
      }
    </div>
  </div>
</Layout>
