---
import { getCollection, getEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const authors = await getCollection("authors");
  return authors.map((author) => ({
    params: { author: author.id },
    props: { author },
  }));
}

const { author } = Astro.props;

const posts = (await getCollection("blog"))
  .filter((post) => post.data.author?.id === author.id)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title={`Posts by ${author.data.name}`}>
  <div class="max-w-2xl mx-auto px-4 py-12">
    <a href="/blog" class="text-indigo-400 text-sm hover:underline mb-8 inline-block">← Back to Blog</a>

    <div class="flex items-center gap-4 mb-10">
      <img
        src={author.data.avatar}
        alt={author.data.name}
        class="w-16 h-16 rounded-full object-cover"
      />
      <div>
        <h1 class="text-2xl font-bold text-slate-100">{author.data.name}</h1>
        <p class="text-slate-400 text-sm">{author.data.bio}</p>
      </div>
    </div>

    <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-widest mb-4">
      {posts.length} {posts.length === 1 ? "post" : "posts"}
    </h2>

    <div class="flex flex-col gap-4">
      {posts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="block bg-slate-800 border border-slate-700 rounded-xl p-6 hover:border-indigo-400 transition-colors no-underline text-inherit"
        >
          <h2 class="text-lg font-semibold mb-2">{post.data.title}</h2>
          <p class="text-slate-400 text-sm mb-2">{post.data.description}</p>
          <span class="text-slate-500 text-xs">
            {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
          </span>
        </a>
      ))}
    </div>
  </div>
</Layout>
