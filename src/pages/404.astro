---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Not Found">
  <main class="flex items-center justify-center min-h-screen px-6">
    <div class="text-center">
      <p class="text-6xl font-bold text-slate-700 mb-4">404</p>
      <p class="text-slate-400 mb-6">Page not found.</p>
      <a href="/" class="text-indigo-400 hover:underline text-sm">← Go home</a>
    </div>
  </main>
</Layout>
